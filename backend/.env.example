# =============================================================================
# Valitek v2 — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL credentials (used by docker-compose AND the connection string)
POSTGRES_USER=valitek
POSTGRES_PASSWORD=change_me
POSTGRES_DB=valitek

# Prisma connection string
# For local dev with docker-compose.dev.yml, the DB is exposed on port 5433.
# Inside Docker containers (docker-compose.yml), use port 5432 and host "db".
DATABASE_URL=postgresql://valitek:change_me@localhost:5433/valitek

# ─── Auth ────────────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens (min 32 characters). Generate one with:
#   openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_GENERATE_A_REAL_SECRET

# ─── Server ──────────────────────────────────────────────────────────────────
# Port the backend listens on (default in dev: 3200)
PORT=3200

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Environment: development | production | test
NODE_ENV=development

# ─── Frontend ────────────────────────────────────────────────────────────────
# URL of the frontend app (used for CORS origin and CSRF checks)
FRONTEND_URL=http://localhost:5173

# ─── Demo Mode ───────────────────────────────────────────────────────────────
# Set to "true" to enable the demo persona switcher on the login page.
# Also enables the /api/demo/reset endpoint.
DEMO_MODE=false

# ─── Backup ──────────────────────────────────────────────────────────────────
# Directory where database backups are stored (default: /app/data/backups)
# BACKUP_DIR=/app/data/backups

# ─── Email (Microsoft 365) ──────────────────────────────────────────────────
# Optional. If not set, email notifications are silently skipped.
# M365_TENANT_ID=
# M365_CLIENT_ID=
# M365_CLIENT_SECRET=
# M365_SENDER_EMAIL=

# ─── SMS (VoIP.ms) ──────────────────────────────────────────────────────────
# Optional. If not set, SMS notifications are silently skipped.
# VOIPMS_USERNAME=
# VOIPMS_PASSWORD=
# VOIPMS_DID=
