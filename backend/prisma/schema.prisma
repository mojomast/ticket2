generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  TECHNICIAN
  ADMIN
}

enum CustomerType {
  RESIDENTIAL
  COMMERCIAL
}

enum ServiceMode {
  SUR_ROUTE
  EN_CUBICULE
}

enum ServiceCategory {
  REPARATION
  LOGICIEL
  RESEAU
  DONNEES
  INSTALLATION
  MAINTENANCE
  CONSULTATION
  FORMATION
  AUTRE
}

enum TicketStatus {
  NOUVELLE
  EN_ATTENTE_APPROBATION
  EN_ATTENTE_REPONSE_CLIENT
  APPROUVEE
  PLANIFIEE
  EN_COURS
  BLOCAGE
  TERMINEE
  FERMEE
  ANNULEE
}

enum Priority {
  BASSE
  NORMALE
  HAUTE
  URGENTE
}

enum AppointmentStatus {
  DEMANDE
  PLANIFIE
  CONFIRME
  EN_COURS
  TERMINE
  ANNULE
}

enum ProposalStatus {
  PROPOSEE
  ACCEPTEE
  REFUSEE
  ANNULEE
}

enum NotificationType {
  TICKET_CREATED
  STATUS_CHANGED
  QUOTE_SENT
  QUOTE_APPROVED
  QUOTE_DECLINED
  NEW_MESSAGE
  BLOCKER_ADDED
  BLOCKER_REMOVED
  TECHNICIAN_ASSIGNED
  APPOINTMENT_BOOKED
  APPOINTMENT_CANCELLED
  APPOINTMENT_PROPOSED
  APPOINTMENT_PROPOSAL_ACCEPTED
  APPOINTMENT_PROPOSAL_REJECTED
  APPOINTMENT_COUNTER_PROPOSED
  BACKUP_COMPLETED
  BACKUP_RESTORED
  WORKSHEET_SUBMITTED
  WORKSHEET_APPROVED
  WORKSHEET_HIGH_VALUE
  FOLLOWUP_REMINDER
}

enum BackupStatus {
  PENDING
  COMPLETED
  FAILED
  RESTORED
}

enum BackupType {
  FULL
  PARTIAL
}

// ─── Work Order (Bon de travail) ───

enum WorkOrderStatus {
  RECEPTION            // Device checked in at counter
  DIAGNOSTIC           // Tech is diagnosing the issue
  ATTENTE_APPROBATION  // Waiting for customer to approve quote
  APPROUVE             // Customer approved, work authorized
  ATTENTE_PIECES       // Waiting for parts to arrive
  EN_REPARATION        // Actively being repaired
  VERIFICATION         // Quality check / testing
  PRET                 // Ready for pickup, customer notified
  REMIS                // Customer picked up device (terminal)
  REFUSE               // Customer declined repair (terminal)
  ABANDONNE            // Device abandoned (terminal)
  ANNULE               // Cancelled (terminal)
}

enum DeviceType {
  LAPTOP
  DESKTOP
  TABLETTE
  TELEPHONE
  TOUT_EN_UN
  IMPRIMANTE
  SERVEUR
  RESEAU_EQUIP
  AUTRE
}

enum DataBackupConsent {
  CLIENT_FAIT          // Customer backed up their own data
  ATELIER_FAIT         // Shop to perform backup
  DECLINE              // Customer declined backup
  NON_APPLICABLE       // Not applicable (e.g., printer)
}

// ─── Knowledge Base ───

enum KbCategory {
  MATERIEL
  LOGICIEL
  RESEAU
  PROCEDURE
  FAQ
  AUTRE
}

enum KbVisibility {
  INTERNAL
  PUBLIC
}

enum KbLinkEntityType {
  TICKET
  WORKORDER
  CUSTOMER
}

// ─── Worksheet (Feuille de travail) ───

enum WorksheetStatus {
  BROUILLON        // Draft — tech is still filling in
  SOUMISE          // Submitted — awaiting admin review
  REVISEE          // Reviewed — admin reviewed, may request changes
  APPROUVEE        // Approved — ready for billing
  FACTUREE         // Billed — invoice generated
  ANNULEE          // Voided — cancelled after approval
}

enum LaborType {
  DIAGNOSTIC
  REPARATION
  INSTALLATION
  CONSULTATION
  GARANTIE         // Warranty work (non-billable or reduced rate)
  REPRISE          // Rework — important for quality metrics
}

enum WorksheetNoteType {
  INTERNE               // Tech-only, never shown to customer
  VISIBLE_CLIENT        // Included on invoice/receipt
  DIAGNOSTIC_FINDING    // Candidate for KB article
  PROCEDURE             // Step-by-step repair procedure, candidate for KB
}

enum FollowUpType {
  VERIFICATION_GARANTIE  // Warranty check
  RAPPEL_CLIENT          // Customer callback
  REVERIFICATION         // Re-check device
  ARRIVEE_PIECES         // Parts arrival
  SUIVI_DEVIS            // Quote follow-up
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  role         UserRole
  customerType CustomerType?
  companyName  String?
  address      String?
  isActive     Boolean       @default(true)
  isDemo       Boolean       @default(false)
  permissions  Json?
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  customerTickets  Ticket[]       @relation("CustomerTickets")
  technicianTickets Ticket[]      @relation("TechnicianTickets")
  appointments     Appointment[]
  messages         Message[]
  notifications    Notification[]
  attachments      Attachment[]
  proposalsAuthored  AppointmentProposal[] @relation("ProposalAuthor")
  proposalsResponded AppointmentProposal[] @relation("ProposalResponder")
  customerWorkOrders   WorkOrder[]     @relation("CustomerWorkOrders")
  technicianWorkOrders WorkOrder[]     @relation("TechnicianWorkOrders")
  intakeByWorkOrders   WorkOrder[]     @relation("IntakeByWorkOrders")
  workOrderNotes       WorkOrderNote[]
  kbArticles           KbArticle[]        @relation("KbArticleAuthor")
  kbArticleLinks       KbArticleLink[]    @relation("KbLinkCreator")
  customerNotesAuthored CustomerNote[]    @relation("CustomerNoteAuthor")
  customerNotesReceived CustomerNote[]    @relation("CustomerNoteTarget")
  worksheetsTechnician  Worksheet[]       @relation("WorksheetTechnician")
  worksheetsReviewed    Worksheet[]       @relation("WorksheetReviewer")
  worksheetsApproved    Worksheet[]       @relation("WorksheetApprover")
  worksheetNotes        WorksheetNote[]   @relation("WorksheetNoteAuthor")

  @@index([role, isActive])
  @@index([deletedAt])
}

model Ticket {
  id               String          @id @default(uuid())
  ticketNumber     String          @unique
  title            String
  description      String
  status           TicketStatus    @default(NOUVELLE)
  priority         Priority        @default(NORMALE)
  serviceMode      ServiceMode     @default(EN_CUBICULE)
  serviceCategory  ServiceCategory @default(REPARATION)
  quotedPrice      Float?
  quoteDescription String?
  quoteDuration    String?
  blockerReason    String?
  customerId       String
  technicianId     String?
  deletedAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  customer      User           @relation("CustomerTickets", fields: [customerId], references: [id], onDelete: Restrict)
  technician    User?          @relation("TechnicianTickets", fields: [technicianId], references: [id], onDelete: SetNull)
  appointments  Appointment[]
  proposals     AppointmentProposal[]
  messages      Message[]
  notifications Notification[]
  attachments   Attachment[]

  @@index([status, createdAt])
  @@index([customerId])
  @@index([technicianId])
  @@index([deletedAt])
}

model Appointment {
  id             String            @id @default(uuid())
  ticketId       String
  technicianId   String?
  scheduledStart DateTime
  scheduledEnd   DateTime
  travelBuffer   Int               @default(0)
  status         AppointmentStatus @default(PLANIFIE)
  notes          String?
  cancelReason   String?
  proposalId     String?           // Link to the proposal that created this appointment
  deletedAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  ticket     Ticket @relation(fields: [ticketId], references: [id])
  technician User?  @relation(fields: [technicianId], references: [id], onDelete: SetNull)
  proposal   AppointmentProposal? @relation(fields: [proposalId], references: [id])

  @@index([ticketId, status])
  @@index([technicianId])
  @@index([scheduledStart])
  @@index([deletedAt])
}

model AppointmentProposal {
  id              String         @id @default(uuid())
  ticketId        String
  proposedById    String
  proposedStart   DateTime
  proposedEnd     DateTime
  message         String?
  status          ProposalStatus @default(PROPOSEE)
  responseMessage String?
  respondedById   String?
  respondedAt     DateTime?
  parentId        String?        // Links counter-proposals to the original
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  ticket      Ticket                @relation(fields: [ticketId], references: [id])
  proposedBy  User                  @relation("ProposalAuthor", fields: [proposedById], references: [id])
  respondedBy User?                 @relation("ProposalResponder", fields: [respondedById], references: [id])
  parent      AppointmentProposal?  @relation("ProposalThread", fields: [parentId], references: [id])
  replies     AppointmentProposal[] @relation("ProposalThread")
  appointments Appointment[]

  @@index([ticketId, status])
  @@index([proposedById])
  @@index([parentId])
  @@index([deletedAt])
}

model Message {
  id         String   @id @default(uuid())
  ticketId   String
  authorId   String
  content    String
  isInternal Boolean  @default(false)
  deletedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  ticket      Ticket       @relation(fields: [ticketId], references: [id])
  author      User         @relation(fields: [authorId], references: [id], onDelete: Restrict)
  attachments Attachment[]

  @@index([ticketId, createdAt])
  @@index([deletedAt])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  ticketId  String?
  type      NotificationType
  title     String
  message   String
  readAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Restrict)
  ticket Ticket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([userId, readAt])
  @@index([ticketId])
}

model Attachment {
  id          String  @id @default(uuid())
  ticketId    String
  messageId   String?
  uploadedBy  String
  fileName    String
  fileSize    Int
  mimeType    String
  storagePath String
  createdAt   DateTime @default(now())

  ticket  Ticket   @relation(fields: [ticketId], references: [id])
  message Message? @relation(fields: [messageId], references: [id])
  uploader User    @relation(fields: [uploadedBy], references: [id])

  @@index([ticketId])
  @@index([messageId])
}

// ─── Work Order (Bon de travail — in-shop repair) ───

model WorkOrder {
  id                  String            @id @default(uuid())
  orderNumber         String            @unique // BDT-YYMMNN format
  status              WorkOrderStatus   @default(RECEPTION)
  priority            Priority          @default(NORMALE)

  // ─── Customer info ───
  customerId          String
  customerName        String             // Denormalized for quick display (walk-in may not have account)
  customerPhone       String
  customerEmail       String?

  // ─── Device info ───
  deviceType          DeviceType         @default(LAPTOP)
  deviceBrand         String             // e.g., Dell, HP, Apple
  deviceModel         String             // e.g., Latitude 5520
  deviceSerial        String?            // Serial number / service tag
  deviceColor         String?
  devicePassword      String?            // Stored for technician access
  deviceOs            String?            // e.g., Windows 11, macOS Ventura

  // ─── Condition & accessories ───
  conditionNotes      String?            // Pre-existing cosmetic condition
  accessories         Json?              // Array of strings: ["Chargeur", "Souris", "Sac"]
  conditionChecklist  Json?              // { screenOk: bool, keyboardOk: bool, ... }

  // ─── Problem & service ───
  reportedIssue       String             // Customer description of the problem
  serviceCategory     ServiceCategory    @default(REPARATION)
  diagnosticNotes     String?            // Tech findings after diagnosis (internal)
  repairNotes         String?            // Work performed (internal)
  partsUsed           Json?              // Array of { name, cost, type: "OEM"|"AFTERMARKET"|"REFURBISHED" }

  // ─── Quote & financial ───
  estimatedCost       Float?             // Initial estimate given at intake
  finalCost           Float?             // Actual cost after repair
  maxAuthorizedSpend  Float?             // Customer-approved ceiling
  depositAmount       Float?             // Deposit collected at intake
  diagnosticFee       Float?             // Non-refundable diagnostic fee

  // ─── Consent & legal ───
  dataBackupConsent   DataBackupConsent  @default(NON_APPLICABLE)
  termsAccepted       Boolean            @default(false)
  termsAcceptedAt     DateTime?
  signatureData       String?            // Base64 signature image (optional for future)

  // ─── Dates ───
  intakeDate          DateTime           @default(now())
  estimatedPickupDate DateTime?
  completedDate       DateTime?          // When repair was finished
  pickupDate          DateTime?          // When customer actually picked up
  abandonedDate       DateTime?          // When marked as abandoned

  // ─── Assignment ───
  intakeById          String             // Tech/Admin who checked in the device
  technicianId        String?            // Assigned repair technician

  // ─── Warranty ───
  warrantyDays        Int?               // e.g., 30, 60, 90
  warrantyStartDate   DateTime?          // Auto-set on completion

  deletedAt           DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  customer    User   @relation("CustomerWorkOrders", fields: [customerId], references: [id], onDelete: Restrict)
  intakeBy    User   @relation("IntakeByWorkOrders", fields: [intakeById], references: [id], onDelete: Restrict)
  technician  User?  @relation("TechnicianWorkOrders", fields: [technicianId], references: [id], onDelete: SetNull)
  notes       WorkOrderNote[]
  worksheets  Worksheet[]

  @@index([status, createdAt])
  @@index([customerId])
  @@index([technicianId])
  @@index([orderNumber])
  @@index([intakeDate])
  @@index([deletedAt])
}

model WorkOrderNote {
  id          String   @id @default(uuid())
  workOrderId String
  authorId    String
  content     String
  isInternal  Boolean  @default(true)  // Most work order notes are internal
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
  author    User      @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([workOrderId, createdAt])
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  action     String
  userId     String
  oldValue   Json?
  newValue   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

model BackupRecord {
  id           String       @id @default(uuid())
  fileName     String
  fileSize     Int
  storagePath  String
  type         BackupType
  status       BackupStatus @default(PENDING)
  tables       Json
  recordCount  Json
  createdBy    String
  restoredAt   DateTime?
  restoredBy   String?
  errorMessage String?
  createdAt    DateTime     @default(now())

  @@index([createdAt])
  @@index([status])
}

// ─── Knowledge Base (Base de connaissances) ───

model KbArticle {
  id         String       @id @default(uuid())
  title      String
  slug       String       @unique
  content    String       // Markdown
  category   KbCategory   @default(AUTRE)
  tags       Json?        // Array of strings
  visibility KbVisibility @default(INTERNAL)
  authorId   String
  deletedAt  DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  author User            @relation("KbArticleAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  links  KbArticleLink[]

  @@index([category, createdAt])
  @@index([visibility])
  @@index([deletedAt])
}

model KbArticleLink {
  id         String           @id @default(uuid())
  articleId  String
  entityType KbLinkEntityType
  entityId   String
  linkedById String
  createdAt  DateTime         @default(now())

  article  KbArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  linkedBy User      @relation("KbLinkCreator", fields: [linkedById], references: [id], onDelete: Restrict)

  @@unique([articleId, entityType, entityId])
  @@index([entityType, entityId])
}

// ─── Customer Notes (Notes client) ───

model CustomerNote {
  id         String    @id @default(uuid())
  customerId String
  authorId   String
  content    String
  isPinned   Boolean   @default(false)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  customer User @relation("CustomerNoteTarget", fields: [customerId], references: [id], onDelete: Restrict)
  author   User @relation("CustomerNoteAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([customerId, isPinned, createdAt])
  @@index([deletedAt])
}

// ─── Worksheet (Feuille de travail — technician work log) ───

model Worksheet {
  id              String          @id @default(uuid())
  workOrderId     String
  technicianId    String
  status          WorksheetStatus @default(BROUILLON)

  // Timestamps
  submittedAt     DateTime?
  reviewedAt      DateTime?
  reviewedById    String?
  approvedAt      DateTime?
  approvedById    String?
  billedAt        DateTime?

  // Signatures (base64 data URIs)
  techSignature   String?         @db.Text
  techSignedAt    DateTime?
  custSignature   String?         @db.Text
  custSignedAt    DateTime?

  // Denormalized totals (recalculated on every mutation)
  totalLabor      Float           @default(0)
  totalParts      Float           @default(0)
  totalTravel     Float           @default(0)
  grandTotal      Float           @default(0)

  // Summary (optional tech summary of all work done)
  summary         String?         @db.Text

  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  workOrder       WorkOrder       @relation(fields: [workOrderId], references: [id], onDelete: Restrict)
  technician      User            @relation("WorksheetTechnician", fields: [technicianId], references: [id], onDelete: Restrict)
  reviewedBy      User?           @relation("WorksheetReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  approvedBy      User?           @relation("WorksheetApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  laborEntries    LaborEntry[]
  parts           PartUsed[]
  travelEntries   TravelEntry[]
  notes           WorksheetNote[]
  followUps       FollowUp[]

  @@index([workOrderId])
  @@index([technicianId])
  @@index([status, createdAt])
  @@index([deletedAt])
}

model LaborEntry {
  id              String      @id @default(uuid())
  worksheetId     String
  laborType       LaborType   @default(REPARATION)
  description     String?

  // Time tracking
  startTime       DateTime
  endTime         DateTime?   // null = timer still running
  breakMinutes    Int         @default(0)

  // Rate
  hourlyRate      Float

  // Computed
  billableHours   Float?
  lineTotal       Float?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  worksheet       Worksheet   @relation(fields: [worksheetId], references: [id], onDelete: Cascade)

  @@index([worksheetId])
}

model PartUsed {
  id              String      @id @default(uuid())
  worksheetId     String

  // Part identification
  partName        String
  partNumber      String?
  supplier        String?

  // Cost & billing
  supplierCost    Float       @default(0)    // What the shop paid
  quantity        Int         @default(1)
  unitPrice       Float                      // Customer-facing price
  lineTotal       Float                      // quantity * unitPrice

  // Warranty
  warrantyMonths  Int?
  warrantyNotes   String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  worksheet       Worksheet   @relation(fields: [worksheetId], references: [id], onDelete: Cascade)

  @@index([worksheetId])
}

model TravelEntry {
  id                String      @id @default(uuid())
  worksheetId       String

  departureAddress  String?
  arrivalAddress    String?
  distanceKm        Float
  travelTimeMinutes Int?

  ratePerKm         Float
  lineTotal         Float       // distanceKm * ratePerKm

  travelDate        DateTime    @default(now())
  notes             String?

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  worksheet         Worksheet   @relation(fields: [worksheetId], references: [id], onDelete: Cascade)

  @@index([worksheetId])
}

model WorksheetNote {
  id              String            @id @default(uuid())
  worksheetId     String
  authorId        String
  noteType        WorksheetNoteType @default(INTERNE)
  content         String            @db.Text

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  worksheet       Worksheet         @relation(fields: [worksheetId], references: [id], onDelete: Cascade)
  author          User              @relation("WorksheetNoteAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([worksheetId])
}

model FollowUp {
  id              String        @id @default(uuid())
  worksheetId     String
  followUpType    FollowUpType
  scheduledDate   DateTime
  notes           String?       @db.Text
  completed       Boolean       @default(false)
  completedAt     DateTime?
  completedById   String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  worksheet       Worksheet     @relation(fields: [worksheetId], references: [id], onDelete: Cascade)

  @@index([worksheetId])
  @@index([scheduledDate, completed])
}
